# Gmail app password (NOT your account password)
# To create an app password:
# 1. Enable 2-factor authentication on your Google account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Select "Mail" and "Windows Computer"
# 4. Copy the generated app password here
# 5. Encrypt it using: mvn exec:java -Dexec.mainClass="com.example.training.util.EncryptTool" -Dexec.args="your-app-password"
# 6. Use the encrypted value as SPRING_MAIL_PASSWORD_ENC
SPRING_MAIL_PASSWORD_ENC=ENC(a8aU+XwSxX0K8e3dR5Z7uQ==)

# ============================================
# Google OAuth2 Configuration
# ============================================
# Get these values from: https://console.cloud.google.com/
# Create an OAuth 2.0 Client ID (Web Application)

# Google Client ID
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Google Client Secret
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================
# Application Configuration
# ============================================
# Server port
SERVER_PORT=8080

# Spring profiles to activate (local or GCP)
SPRING_PROFILES_ACTIVE=local

# ============================================
# Optional Logging Configuration
# ============================================
# Uncomment to enable debug logging
# LOGGING_LEVEL_ROOT=INFO
# LOGGING_LEVEL_COM_EXAMPLE_TRAINING=DEBUG

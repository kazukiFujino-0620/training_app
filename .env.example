# Environment Variables Template for Local Development
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ============================================
# Jasypt Encryption Configuration
# ============================================
# Master password for Jasypt encryption/decryption
# Change this for production environments
JASYPT_ENCRYPTOR_PASSWORD=local-dev-password

# ============================================
# Database Configuration
# ============================================
# Used by Maven profiles (see pom.xml)
# Local development uses root with empty password
# GCP environment uses springuser with encrypted password

# Database URL for Maven filtering
DB_URL=jdbc:mysql://localhost:3306/training_db?serverTimezone=Asia/Tokyo

# Database username
DB_USERNAME=root

# Database password (empty for local development)
DB_PASSWORD=

# ============================================
# Gmail SMTP Configuration
# ============================================
# Gmail account email

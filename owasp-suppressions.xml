<?xml version="1.0" encoding="UTF-8"?>
<!--
    OWASP Dependency-Check の誤検知抑止ファイル。
    本ファイルに記載した CVE はスキャン結果から除外される。
    誤検知が発生した場合のみ、根拠（GitHub Issue / 公式アナウンス）を
    コメントに記載した上で追記すること。
-->
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!-- サンプル: 必要に応じて追加
    <suppress>
        <notes><![CDATA[
        CVE-XXXX-XXXX は本プロジェクトでは該当しない。
        理由: ...
        確認日: 2026-05-27
        ]]></notes>
        <packageUrl regex="true">^pkg:maven/org\.example/.*$</packageUrl>
        <cve>CVE-XXXX-XXXX</cve>
    </suppress>
    -->
</suppressions>

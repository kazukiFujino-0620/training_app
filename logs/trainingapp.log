2026-06-03 21:38:37.271 [http-nio-8080-exec-5] INFO  o.s.doma.jdbc.UtilLoggingJdbcLogger - [DOMA2076] SQL LOG : PATH=[META-INF/com/example/traning/training/dao/TrainingDetailDao/selectGrowthByItemAndPeriod.sql],
SELECT
    DATE_FORMAT(MIN(t.training_date), '%Y-%m-%d') AS week_label,
    MAX(td.weight)                                 AS max_weight,
    SUM(td.weight * td.reps)                       AS total_volume
FROM training_details td
JOIN trainings t ON t.id = td.training_id
WHERE t.user_id       = 5
  AND t.menu          = 'インクラインダンベルカール'
  AND t.training_date BETWEEN '2026-03-03'
                          AND '2026-06-03'
  AND t.deleted_at    IS NULL
  AND td.deleted_at   IS NULL
GROUP BY  YEARWEEK(t.training_date, 3)
ORDER BY  YEARWEEK(t.training_date, 3)
